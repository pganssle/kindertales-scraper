[account]
email = "parent@example.com"

[authentication]
allow_plaintext_session_cache = false
cache_directory = ".cache/kindertales-scraper"

[archive]
directory = "archive"
folder_format = "" # e.g. "{child_name}" or "{child_name}/{activity_type}"
folder_frequency = "none" # none, daily, monthly, or yearly
filename_format = "{timestamp:%Y%m%d_%H%M%S}_{sequence:02d}{extension}"
sidecar_layout = "adjacent" # adjacent or parallel

[exports]
child_records = true
messages = false # Inbox, sent, draft, scheduled, and contact listings.
billing = false # Billing dashboard, including payment-related information.

[children]
use_kindertales_name = false

[children.names]
# "Child-2" = "Mark"

[synchronization]
overlap_days = 7

[request_policy]
max_in_flight = 8
max_media_downloads = 2
jitter_fraction = 0.10
max_retries = 3
stop_after_forbidden = 3
quotas = [
    { count = 8, window_seconds = 1.0 },
    { count = 120, window_seconds = 60.0 },
]

[metadata]

# Missing center values inherit from this table. Latitude and longitude must
# always be specified together. GPS uncertainty is a horizontal radius in meters.
# [metadata.defaults.center]
# latitude = 40.7128
# longitude = -74.0060
# timezone = "America/New_York"
# gps_uncertainty_meters = 250.0

# Repeat for each Kindertales center. Keys are Kindertales center IDs.
# [metadata.centers."center-123"]
# latitude = 40.7128
# longitude = -74.0060
# timezone = "America/New_York"
# gps_uncertainty_meters = 50.0
